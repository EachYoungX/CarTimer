<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ==================== 深色模式语义化主题样式定义 ==================== -->
    
    <!-- ========== 基础主题 (经典蓝 - 深色模式) ========== -->
    <style name="Base.Theme.CarTimer.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color (保持不变). -->
        <item name="colorPrimary">@color/theme_blue_primary</item>
        <item name="colorPrimaryVariant">@color/theme_blue_primary_variant</item>
        <item name="colorOnPrimary">@color/theme_blue_on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/theme_blue_secondary</item>
        <item name="colorSecondaryVariant">@color/theme_blue_primary_variant</item>
        <item name="colorOnSecondary">@color/theme_blue_on_secondary</item>
        <!-- Background color (强制深色). -->
        <item name="android:colorBackground">@color/theme_blue_background</item>
        <item name="colorOnBackground">@color/theme_blue_on_surface</item>
        <!-- Surface color (强制深色). -->
        <item name="colorSurface">@color/theme_blue_surface</item>
        <item name="colorSurfaceVariant">@color/theme_blue_surface_variant</item>
        <item name="colorOnSurface">@color/theme_blue_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/theme_blue_on_surface_variant</item>
        <!-- Outline color. -->
        <item name="colorOutline">@color/theme_blue_outline</item>
        <!-- Error color. -->
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@color/color_on_error</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
    
    <!-- ========== 经典蓝主题 - 深色模式 ========== -->
    <style name="Theme.CarTimer.Blue" parent="Base.Theme.CarTimer.Dark" />
    
