<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ==================== 语义化主题样式定义 ==================== -->
    
    <!-- ========== 基础主题 (经典蓝 - 浅色模式) ========== -->
    <style name="Base.Theme.CarTimer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/theme_blue_primary</item>
        <item name="colorPrimaryVariant">@color/theme_blue_primary_variant</item>
        <item name="colorOnPrimary">@color/theme_blue_on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/theme_blue_secondary</item>
        <item name="colorSecondaryVariant">@color/theme_blue_primary_variant</item>
        <item name="colorOnSecondary">@color/theme_blue_on_secondary</item>
        <!-- Background color. -->
        <item name="android:colorBackground">@color/theme_blue_background_light</item>
        <item name="colorOnBackground">@color/theme_blue_on_surface_light</item>
        <!-- Surface color. -->
        <item name="colorSurface">@color/theme_blue_surface_light</item>
        <item name="colorOnSurface">@color/theme_blue_on_surface_light</item>
        <item name="colorSurfaceVariant">@color/theme_blue_surface_variant_light</item>
        <item name="colorOnSurfaceVariant">@color/theme_blue_on_surface_variant_light</item>
        <!-- Outline color. -->
        <item name="colorOutline">@color/theme_blue_outline_light</item>
        <!-- Error color. -->
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@color/color_on_error</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
    
    <!-- ========== 经典蓝主题 ========== -->
    <style name="Theme.CarTimer.Blue" parent="Base.Theme.CarTimer" />
    
